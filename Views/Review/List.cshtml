@model IEnumerable<Task6.Models.Recenzija>

@{
    ViewData["Title"] = "Recenzije za " + ViewBag.Room.Naziv;
    var room = (Task6.Models.EscapeRoom)ViewBag.Room;
    var averageRating = (double)ViewBag.AverageRating;
}

<div class="container mt-5">
    <h1>Recenzije za "@room.Naziv"</h1>

    <div class="mb-4">
        <p class="h5">Prosječna ocjena: <span class="badge bg-success">@averageRating.ToString("F1") / 5.0</span></p>
    </div>

    <div class="mb-4">
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-controller="Review" asp-action="Create" asp-route-roomId="@ViewBag.RoomId" class="btn btn-primary">
                Dodaj recenziju
            </a>
        }
        else
        {
            <p><a asp-controller="Account" asp-action="Login">Prijavite se</a> da dodate recenziju</p>
        }
    </div>

    @if (Model.Any())
    {
        @foreach (var review in Model)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="card-title">@review.Korisnik.Ime @review.Korisnik.Prezime</h5>
                            <p class="text-muted small">@review.Datum.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                        <div class="text-warning">
                            <span class="h5">@review.Ocjena.ToString("F1") ⭐</span>
                        </div>
                    </div>
                    <p class="card-text">@review.Komentar</p>

                    @if (User.Identity?.Name == review.Korisnik.UserName || User.IsInRole("Admin"))
                    {
                        <a asp-controller="Review" asp-action="Edit" asp-route-id="@review.RecenzijaID" class="btn btn-sm btn-warning">Uredi</a>
                        <a asp-controller="Review" asp-action="Delete" asp-route-id="@review.RecenzijaID" class="btn btn-sm btn-danger">Obriši</a>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info" role="alert">
            Nema recenzija za ovu sobu. Budite prvi koji će ostaviti recenziju!
        </div>
    }

    <a asp-controller="Room" asp-action="Details" asp-route-id="@ViewBag.RoomId" class="btn btn-secondary mt-3">
        Nazad na detalje sobe
    </a>
</div>
