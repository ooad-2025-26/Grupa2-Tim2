@model Task6.Models.Recenzija

@{
    ViewData["Title"] = "Dodaj recenziju";
    var room = (Task6.Models.EscapeRoom)ViewBag.Room;
}

<div class="review-create-page">
    <div class="review-create-container">

        <a asp-controller="Review"
               asp-action="List"
               asp-route-roomId="@room.RoomID"
               class="review-create-back">
            ← Nazad na recenzije
        </a>

        <div class="review-create-card">
            <p class="review-create-subtitle">THE LAST KEY</p>

            <h1>Dodaj recenziju</h1>

            <p class="review-create-description">
                Podijelite svoje iskustvo za sobu
                <strong>"@room.Naziv"</strong>.
            </p>

            <form method="post" class="review-create-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roomId" value="@room.RoomID" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="review-field">
                    <label asp-for="Ocjena">
                        Ocjena
                    </label>

                    <input asp-for="Ocjena"
                           type="number"
                           min="1"
                           max="5"
                           step="0.5"
                           placeholder="Unesite ocjenu od 1 do 5"
                           required />

                    <span asp-validation-for="Ocjena" class="text-danger"></span>
                </div>

                <div class="review-field">
                    <label asp-for="Komentar">
                        Komentar
                    </label>

                    <textarea asp-for="Komentar"
                              rows="6"
                              placeholder="Podijelite vaše iskustvo..."></textarea>

                    <span asp-validation-for="Komentar" class="text-danger"></span>
                </div>

                <div class="review-create-actions">
                    <button type="submit" class="review-submit-btn">
                        Pošalji recenziju
                    </button>

                    <a asp-controller="Review"
                           asp-action="List"
                           asp-route-roomId="@room.RoomID"
                           class="review-cancel-btn">
                        Otkaži
                    </a>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}