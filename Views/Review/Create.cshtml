@model Task6.Models.Recenzija 

@{
    ViewData["Title"] = "Dodaj recenziju";
    var room = (Task6.Models.EscapeRoom)ViewBag.Room;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>Dodaj recenziju za "@room.Naziv"</h1>

            <form method="post" class="mt-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Ocjena" class="form-label">Ocjena (1-5):</label>
                    <input asp-for="Ocjena" type="number" class="form-control" min="1" max="5" step="0.5" required />
                    <span asp-validation-for="Ocjena" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Komentar" class="form-label">Komentar:</label>
                    <textarea asp-for="Komentar" class="form-control" rows="5" placeholder="Podijelite vašu iskustvo..."></textarea>
                    <span asp-validation-for="Komentar" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Pošalji recenziju</button>
                    <a asp-controller="Review" asp-action="List" asp-route-roomId="@ViewBag.RoomId" class="btn btn-secondary">Otkaži</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
