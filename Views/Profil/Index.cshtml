@model IEnumerable<Task6.Models.Rezervacija>

@{
    ViewData["Title"] = "Moj profil";
    var user = ViewBag.User as Task6.Models.ApplicationUser;
}

<div class="profile-page">
    <div class="profile-container">

        <div class="profile-header">
            <div>
                <p class="profile-small-title">THE LAST KEY</p>
                <h1>Moj profil</h1>

            </div>
            <a asp-controller="Home"
                   asp-action="Index"
                   class="home-btn">
                Početna
            </a>


            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">Odjavi se</button>
            </form>
        </div>

        <div class="profile-card">
            <div class="profile-avatar">
                @(user?.Ime?.Substring(0, 1))@(user?.Prezime?.Substring(0, 1))
            </div>

            <div class="profile-info">
                <h2>@user?.Ime @user?.Prezime</h2>

                <p><strong>Email:</strong> @user?.Email</p>
                <p><strong>Uloga:</strong> @user?.Uloga</p>

                @if (user?.Uloga == Task6.Models.Uloga.Admin)
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="admin-profile-btn">
                        Otvori Admin Panel
                    </a>
                }

                @if (user?.Uloga == Task6.Models.Uloga.Zaposlenik)
                {
                    <a asp-controller="Zaposlenik" asp-action="Dashboard" class="admin-profile-btn">
                        Otvori Zaposlenik Panel
                    </a>
                }

                
            </div>
        </div>

        @if (TempData["PaymentSuccess"] != null)
        {
            <div class="alert alert-success">@TempData["PaymentSuccess"]</div>
        }

        @if (TempData["PaymentError"] != null)
        {
            <div class="alert alert-danger">@TempData["PaymentError"]</div>
        }

        @if (TempData["PaymentInfo"] != null)
        {
            <div class="alert alert-info">@TempData["PaymentInfo"]</div>
        }

        <div class="reservations-section">
            <h3>Moje rezervacije</h3>
            @{
                var placeneRezervacije = ViewBag.PlaceneRezervacije as List<int> ?? new List<int>();
            }

            @if (Model.Any())
            {
                <div class="profile-table-wrapper">
                    <table class="profile-table">
                        <thead>
                            <tr>
                                <th>Soba</th>
                                <th>Datum</th>
                                <th>Vrijeme</th>
                                <th>Broj osoba</th>
                                <th>Status</th>
                                <th>Kreirano</th>
                                <th>Akcije</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var reservation in Model)
                            {
                                <tr>
                                    <td>@reservation.Termin.EscapeRoom.Naziv</td>
                                    <td>@reservation.Termin.Datum.ToString("dd.MM.yyyy")</td>
                                    <td>@reservation.Termin.Vrijeme</td>
                                    <td>@reservation.BrojOsoba</td>

                                    <td>
                                        @if (reservation.Status)
                                        {
                                            <span class="status-badge status-ok">Potvrđena</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-cancel">Otkazana</span>
                                        }
                                    </td>

                                    <td>@reservation.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</td>

                                    <td class="action-buttons">
                                        <a asp-controller="Reservation"
                                           asp-action="Details"
                                           asp-route-id="@reservation.RezervacijaID"
                                           class="details-btn">
                                            Detalji
                                        </a>
                                       
                                        @if (!placeneRezervacije.Contains(reservation.RezervacijaID))
                                        {
                                            <a asp-controller="Payment"
                                                   asp-action="Pay"
                                                   asp-route-reservationId="@reservation.RezervacijaID"
                                                   class="details-btn">
                                                Plati online
                                            </a>
                                        }

                                        @if (reservation.Termin.Datum > DateTime.UtcNow.AddHours(24) && reservation.Status)
                                        {
                                            <form asp-controller="Reservation" asp-action="Cancel" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@reservation.RezervacijaID" />
                                                <button type="submit" class="cancel-btn">Otkaži</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-reservations">
                    Nemate rezervacija.
                </div>
            }
        </div>
    </div>
</div>