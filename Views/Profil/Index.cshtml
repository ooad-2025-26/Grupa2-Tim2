@model IEnumerable<Task6.Models.Rezervacija>

@{
    ViewData["Title"] = "Moj profil";
    var user = ViewBag.User as Task6.Models.ApplicationUser;
}

<div class="container mt-5">
    <h1>Moj profil</h1>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@user?.Ime @user?.Prezime</h5>
            <p class="card-text"><strong>Email:</strong> @user?.Email</p>
            <p class="card-text"><strong>Uloga:</strong> @user?.Uloga</p>
        </div>
    </div>

    <h3>Moje rezervacije</h3>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Soba</th>
                        <th>Datum</th>
                        <th>Vrijeme</th>
                        <th>Broj osoba</th>
                        <th>Status</th>
                        <th>Kreirano</th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model)
                    {
                        <tr>
                            <td>@reservation.Termin.EscapeRoom.Naziv</td>
                            <td>@reservation.Termin.Datum.ToString("dd.MM.yyyy")</td>
                            <td>@reservation.Termin.Vrijeme</td>
                            <td>@reservation.BrojOsoba</td>
                            <td>
                                @if (reservation.Status)
                                {
                                    <span class="badge bg-success">Potvrđena</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Otkazana</span>
                                }
                            </td>
                            <td>@reservation.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@reservation.RezervacijaID" class="btn btn-sm btn-info">Detalji</a>
                                @if (reservation.Termin.Datum > DateTime.Now.AddHours(24) && reservation.Status)
                                {
                                    <form asp-action="Cancel" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@reservation.RezervacijaID" />
                                        <button type="submit" class="btn btn-sm btn-danger">Otkaži</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Nemate rezervacija.</div>
    }
</div>
