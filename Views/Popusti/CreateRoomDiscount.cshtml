@model Task6.ViewModels.RoomDiscountViewModel

@{
    ViewData["Title"] = "Postavi popust";
}

<div class="container mt-4">
    <div class="admin-header mb-4">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Popust za sobu: @Model.EscapeRoomName</h1>
        </div>

        <a asp-controller="Popusti" asp-action="Index" class="home-btn">Povratak na popuste</a>
    </div>

    <div class="admin-form-card">
        <form asp-action="CreateRoomDiscount" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EscapeRoomId" />

            <div class="mb-3">
                <label asp-for="DiscountPercent" class="form-label">Popust (%)</label>
                <input asp-for="DiscountPercent" class="form-control" min="1" max="100" />
                <span asp-validation-for="DiscountPercent" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label">Datum početka</label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EndDate" class="form-label">Datum završetka</label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <button type="submit" class="admin-add-btn">Spremi popust</button>
        </form>
    </div>
</div>
