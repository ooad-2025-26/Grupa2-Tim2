@model IEnumerable<Task6.Models.Obavijest>

@{
    ViewData["Title"] = "Popusti";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Popusti</h1>
        </div>
        <a asp-controller="Popusti" asp-action="Create" class="admin-add-btn">+ Novi popust</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="admin-table-box">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Naslov</th>
                        <th>Sadržaj</th>
                        <th>Datum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var popust in Model)
                    {
                        <tr>
                            <td>@popust.ObavijestID</td>
                            <td>@popust.Naslov</td>
                            <td>@(popust.Sadrzaj.Length > 120 ? popust.Sadrzaj.Substring(0, 120) + "..." : popust.Sadrzaj)</td>
                            <td>@popust.Datum.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-reservations">
            Nema popusta.
        </div>
    }
</div>
