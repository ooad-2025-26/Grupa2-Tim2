@{
    ViewData["Title"] = "Online plaćanje";
    var rezervacija = ViewBag.Rezervacija as Task6.Models.Rezervacija;
    var iznos = ViewBag.Iznos;
}

<div class="payment-page">
    <div class="payment-card">
        <a asp-controller="Profil"
               asp-action="Index"
               class="back-profile-btn">
            ← Nazad na profil
        </a>

        <h1>Online plaćanje</h1>
        <p class="payment-subtitle">Dovršite rezervaciju sigurnim unosom podataka kartice.</p>

        <div class="reservation-box">
            <h5>@rezervacija?.Termin.EscapeRoom.Naziv</h5>
            <p><strong>Datum:</strong> @rezervacija?.Termin.Datum.ToString("dd.MM.yyyy")</p>
            <p><strong>Vrijeme:</strong> @rezervacija?.Termin.Vrijeme</p>
            <p><strong>Broj osoba:</strong> @rezervacija?.BrojOsoba</p>
            <p><strong>Iznos:</strong> <span>@iznos KM</span></p>
        </div>

        <form asp-controller="Payment" asp-action="Pay" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="reservationId" value="@rezervacija?.RezervacijaID" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Ime na kartici</label>
                <input type="text" name="imeNaKartici" class="form-control" minlength="3" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Broj kartice</label>
                <input type="text"
                       name="brojKartice"
                       class="form-control"
                       placeholder="1234 5678 9012 3456"
                       maxlength="19"
                       pattern="[0-9 ]{16,19}"
                       title="Broj kartice mora imati tačno 16 cifara."
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label">Datum isteka</label>
                <input type="text"
                       id="datumIsteka"
                       name="datumIsteka"
                       class="form-control"
                       placeholder="MM/YY"
                       maxlength="5"
                       pattern="(0[1-9]|1[0-2])/[0-9]{2}"
                       title="Datum mora biti u formatu MM/YY, npr. 12/29."
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label">CVV</label>
                <input type="password"
                       name="cvv"
                       class="form-control"
                       maxlength="3"
                       pattern="[0-9]{3}"
                       title="CVV mora imati tačno 3 cifre."
                       required />
            </div>

            <div class="payment-buttons">
                <button type="submit" class="btn-pay">Plati</button>
                <a asp-controller="Profil" asp-action="Index" class="btn-cancel">Odustani</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById("datumIsteka").addEventListener("input", function () {
        let value = this.value.replace(/\D/g, "");

        if (value.length > 2) {
            value = value.substring(0, 2) + "/" + value.substring(2, 4);
        }

        this.value = value;
    });
</script>