    <!-- SCRIPT -->

    <script>

            /* LOGIN */

            const loginBtn = document.querySelector(".btn-login");
            const loginModal = document.getElementById("loginModal");
            const closeLogin = document.getElementById("closeLogin");

            loginBtn.addEventListener("click", function(e) {

                e.preventDefault();

                loginModal.classList.add("show-login");

            });

            closeLogin.addEventListener("click", function() {

                loginModal.classList.remove("show-login");

            });

            /* REGISTER */

            const registerBtn = document.querySelector(".btn-register");
            const registerModal = document.getElementById("registerModal");
            const closeRegister = document.getElementById("closeRegister");

            registerBtn.addEventListener("click", function(e) {

                e.preventDefault();

                registerModal.classList.add("show-register");

            });

            closeRegister.addEventListener("click", function() {

                registerModal.classList.remove("show-register");

            });
                        /* MURDER ROOM */

            document.addEventListener("DOMContentLoaded", function() {

                const murderBtn = document.querySelector(".murder-btn");

                const murderModal = document.getElementById("murderModal");

                const closeMurderModal = document.getElementById("closeMurderModal");

                murderBtn.addEventListener("click", function(e) {

                    e.preventDefault();

                    murderModal.classList.add("show-room-modal");

                });

                closeMurderModal.addEventListener("click", function() {

                    murderModal.classList.remove("show-room-modal");

                });

                window.addEventListener("click", function(e) {

                    if (e.target === murderModal) {

                        murderModal.classList.remove("show-room-modal");
                    }

                });

            });

            /* CLOSE WHEN CLICK OUTSIDE */

            window.addEventListener("click", function(e) {

                if (e.target === loginModal) {

                    loginModal.classList.remove("show-login");
                }

                if (e.target === registerModal) {

                    registerModal.classList.remove("show-register");
                }

                          

            });


                                   /* CLASSROOM ROOM */

            document.addEventListener("DOMContentLoaded", function () {

                const classroomBtn = document.querySelector(".classroom-btn");

                const classroomModal = document.getElementById("classroomModal");

                const closeClassroomModal = document.getElementById("closeClassroomModal");

                classroomBtn.addEventListener("click", function (e) {

                    e.preventDefault();

                    classroomModal.classList.add("show-room-modal");

                });

                closeClassroomModal.addEventListener("click", function () {

                    classroomModal.classList.remove("show-room-modal");

                });

                window.addEventListener("click", function (e) {

                    if (e.target === classroomModal) {

                        classroomModal.classList.remove("show-room-modal");

                    }

                });

            });

    </script>
