

@using Microsoft.AspNetCore.Identity
@using Task6.Models
@model IEnumerable<Task6.Models.EscapeRoom>
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<body>

   

    <!-- HERO -->

    <section class="hero">

        <nav class="navbar">

            <div class="logo">
                <h2>THE LAST <span>key</span></h2>
            </div>

            <ul class="nav-links">
                <li><a href="#about">O NAMA</a></li>
                <li><a href="#rooms">SOBE</a></li>
                <li><a href="#contact">KONTAKT I PODRŠKA</a></li>
                <a href="#faq">ČESTA PITANJA</a>
            </ul>

            <div class="nav-buttons">

                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUser = await UserManager.GetUserAsync(User);

                    <a asp-controller="Profil"
                       asp-action="Index"
                       class="btn-login">
                        @(currentUser?.Ime ?? "Moj Profil")
                    </a>

                    <form asp-controller="Account"
                          asp-action="Logout"
                          method="post"
                          style="display:inline;">

                        <button type="submit"
                                class="btn-register">
                            Odjava
                        </button>

                    </form>
                }
                 
                else
                {
                    <a href="/Account/Login"
                       class="btn-login">
                        Prijava
                    </a>

                    <a href="/Account/Register"
                       class="btn-register">
                        Registracija
                    </a>
                }
               
            </div>

        </nav>

        <!-- HERO CONTENT -->

        <div class="hero-content">

            <p class="subtitle">DOBRODOŠLI U</p>

            <h1>
                THE LAST <span>key</span>
            </h1>

            <p class="description">
                Otkrijte naše aktivne sobe i započnite avanturu klikom na
                dugme ispod.
            </p>

            <div class="hero-buttons">
                <a href="#rooms" class="btn-orange">Istraži Sobe</a>
            </div>

        </div>

    </section>

    <!-- ABOUT SECTION -->

    <section id="about" class="about-section">

        <div class="about-content">

            <p class="about-subtitle">
                O NAMA
            </p>

            <h2 class="about-title">
                THE LAST KEY <br>
                SARAJEVO
            </h2>

            <p class="about-text">
                The Last Key Sarajevo otvoren je 2023. godine sa ciljem da ljubiteljima
                misterije, adrenalina i timskog duha pruži potpuno novo escape room iskustvo.
                Inspirisani svjetskim escape konceptima, kreirali smo prostor u kojem svaka
                soba priča jedinstvenu priču i pretvara igrače u glavne junake avanture.
            </p>

            <p class="about-text">
                Tokom protekle dvije godine kroz naše sobe prošlo je više od 5000 igrača,
                uključujući prijateljske grupe, porodice, turiste, kompanije i studentske
                organizacije. Posebno smo ponosni na team building događaje koji okupljaju
                timove kroz saradnju, logiku i zabavu.
            </p>

            <p class="about-text">
                Naš cilj nije samo igra, već stvaranje iskustva koje se pamti.
                Od misterioznih istraga i laboratorijskih eksperimenata do magičnih akademija,
                svaka avantura osmišljena je tako da testira kreativnost, komunikaciju i
                snalažljivost igrača pod pritiskom vremena.
            </p>

        </div>

    </section>

    <!-- ROOMS SECTION -->

    <section id="rooms" class="rooms-section">

        <div class="rooms-content rooms-hover-container">

            <p class="rooms-subtitle">
                AKTIVNE SOBE
            </p>

            <h2 class="rooms-hover-title">
                Istraži naše misterije
            </h2>

            <p class="rooms-text">
                Zakoračite u svijet zagonetki, tajni i adrenalina.
                Svaka soba krije novu priču koju morate otkriti.
            </p>

            <div class="all-rooms-link-wrapper">
                <a asp-controller="Room"
                   asp-action="Index"
                   class="all-rooms-link">
                    Pogledaj sve sobe →
                </a>
            </div>



            <!-- ESCAPE ROOM CARDS -->

            <div class="escape-cards">

                @foreach (var room in Model.Take(5))
                {
                    var imagePath = "";

                    if (!string.IsNullOrEmpty(room.ImageUrl))
                    {
                        imagePath = room.ImageUrl;
                    }
                    else
                    {
                        if (room.Naziv.Contains("Murder", StringComparison.OrdinalIgnoreCase))
                            imagePath = "/images/murder1.webp";
                        else if (room.Naziv.Contains("Classroom", StringComparison.OrdinalIgnoreCase))
                            imagePath = "/images/classroom1.jpg";
                        else if (room.Naziv.Contains("Lab", StringComparison.OrdinalIgnoreCase))
                            imagePath = "/images/lab1.jpg";
                        else if (room.Naziv.Contains("Magic", StringComparison.OrdinalIgnoreCase))
                            imagePath = "/images/magic1.jpeg";
                        else if (room.Naziv.Contains("Haunted", StringComparison.OrdinalIgnoreCase))
                            imagePath = "/images/haunted1.jpg";
                        else
                            imagePath = "/images/outbreak-lab.jpeg";
                    }

                    <div class="escape-card">

                        <div class="card-image">
                            <img src="@imagePath" alt="@room.Naziv">
                        </div>

                        <div class="card-content">

                            <h3>@room.Naziv</h3>

                            <p>@room.Opis</p>

                            <div class="card-info">
                                <span>👥 do @room.Kapacitet osoba</span>
                                <span>🧩 @room.Tezina</span>
                            </div>

                            <a asp-controller="EscapeRooms"
                               asp-action="Details"
                               asp-route-id="@room.RoomID"
                               class="card-btn">
                                Pregled sobe
                            </a>

                        </div>

                    </div>
                }

            </div>

        </div>
    </section>
    </section>


    <!-- FAQ SECTION -->

    <section id="faq" class="faq-section">

        <div class="faq-container">

            <p class="faq-subtitle">
                ČESTA PITANJA
            </p>

            <h2 class="faq-title">
                Sve što trebate znati prije rezervacije
            </h2>

            <p class="faq-text">
                Pronađite odgovore na najčešća pitanja vezana za rezervacije,
                trajanje igara, broj igrača i pravila escape room iskustva.
            </p>

            <div class="faq-wrapper">

                <!-- ITEM -->

                <div class="faq-item">

                    <button class="faq-question">
                        Koliko traje jedna escape room igra?
                        <span>+</span>
                    </button>

                    <div class="faq-answer">

                        <p>
                            Većina naših escape room avantura traje između
                            45 i 80 minuta, zavisno od odabrane sobe.
                        </p>

                    </div>

                </div>

                <!-- ITEM -->

                <div class="faq-item">

                    <button class="faq-question">
                        Da li je potrebna prethodna rezervacija?
                        <span>+</span>
                    </button>

                    <div class="faq-answer">

                        <p>
                            Da. Rezervacija termina je obavezna kako bismo
                            osigurali dostupnost sobe i pripremili iskustvo za vaš tim.
                        </p>

                    </div>

                </div>

                <!-- ITEM -->

                <div class="faq-item">

                    <button class="faq-question">
                        Koliko igrača može učestvovati?
                        <span>+</span>
                    </button>

                    <div class="faq-answer">

                        <p>
                            Broj igrača zavisi od sobe, ali većina naših
                            avantura podržava između 2 i 7 učesnika.
                        </p>

                    </div>

                </div>

                <!-- ITEM -->

                <div class="faq-item">

                    <button class="faq-question">
                        Šta ako zakasnimo na rezervisani termin?
                        <span>+</span>
                    </button>

                    <div class="faq-answer">

                        <p>
                            Preporučujemo dolazak najmanje 10 minuta ranije.
                            Veća kašnjenja mogu skratiti trajanje igre.
                        </p>

                    </div>

                </div>

                <!-- ITEM -->

                <div class="faq-item">

                    <button class="faq-question">
                        Da li su sobe prilagođene početnicima?
                        <span>+</span>
                    </button>

                    <div class="faq-answer">

                        <p>
                            Naravno. Imamo sobe različitih težina —
                            od početničkih do naprednih izazova.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- CONTACT SECTION -->

    <section id="contact" class="contact-section">

        <div class="contact-container">

            <p class="contact-subtitle">
                KONTAKT I PODRŠKA
            </p>

            <h2 class="contact-title">
                Posjetite nas u srcu Sarajeva
            </h2>

            <p class="contact-text">
                Za rezervacije, dodatne informacije ili podršku naš tim vam je uvijek na raspolaganju.
                Posjetite nas na adresi ispod ili nas kontaktirajte direktno.
            </p>

        <div class="question-link-container">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-controller="Support"
                   asp-action="Contact"
                   class="support-question-link">
                    Imate dodatnih pitanja?
                </a>
            }
            else
            {
                <a asp-controller="Account"
                   asp-action="Login"
                   class="support-question-link">
                    Kontaktirajte nas
                </a>
            }
        </div>

           

            <div class="contact-wrapper">

                <!-- LIJEVA STRANA -->

                <div class="contact-left">

                    <!-- ADRESA -->

                <div class="contact-card">

                    <h3>📍 Adresa</h3>

                    <p class="contact-main">
                        Fra Anđela Zvizdovića 3
                    </p>

                    <p class="contact-secondary">
                        Sarajevo, Bosna i Hercegovina
                    </p>

                </div>

                    <!-- KONTAKT -->

                <div class="contact-card">

                    <h3>📞 Kontakt</h3>

                    <p class="contact-main">
                        +387 61 234 567
                    </p>

                    <p class="contact-secondary">
                        thelastkey71000@gmail.com
                    </p>

                </div>

                </div>

                <!-- MAPA -->

                <div class="map-container">

                    <img src="/images/mapa.png" alt="Mapa">

                    <div class="map-pin">
                        📍
                    </div>

                </div>

            </div>

        </div>

    </section>

