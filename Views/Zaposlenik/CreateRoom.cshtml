@model Task6.Models.EscapeRoom

@{
    ViewData["Title"] = "Kreiraj novu sobu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>Kreiraj novu Escape sobu</h1>

            <form method="post" class="card p-4 mt-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Naziv" class="form-label"></label>
                    <input asp-for="Naziv" class="form-control" placeholder="Naziv sobe" />
                    <span asp-validation-for="Naziv" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Opis" class="form-label"></label>
                    <textarea asp-for="Opis" class="form-control" rows="4" placeholder="Opis sobe"></textarea>
                    <span asp-validation-for="Opis" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Tezina" class="form-label"></label>
                        <select asp-for="Tezina" class="form-select">
                            <option value="Lagana">Lagana</option>
                            <option value="Srednja">Srednja</option>
                            <option value="Teska">Teška</option>
                        </select>
                        <span asp-validation-for="Tezina" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Kapacitet" class="form-label"></label>
                        <input asp-for="Kapacitet" type="number" class="form-control" min="1" max="20" />
                        <span asp-validation-for="Kapacitet" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Cijena" class="form-label"></label>
                    <input asp-for="Cijena" type="number" class="form-control" step="0.01" />
                    <span asp-validation-for="Cijena" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Kreiraj sobu</button>
                    <a asp-controller="Zaposlenik" asp-action="Rooms" class="btn btn-secondary">Otkaži</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
