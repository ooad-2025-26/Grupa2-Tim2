@model IEnumerable<Task6.Models.Obavijest>

@{
    ViewData["Title"] = "Upravljanje obavijestima";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upravljanje obavijestima</h1>

    <a asp-controller="Zaposlenik"
           asp-action="CreateNotification"
           class="btn btn-success mb-3">
        + Nova obavijest
    </a>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Naslov</th>
                    <th>Sadržaj</th>
                    <th>Tip</th>
                    <th>Datum</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var notif in Model)
                {
                    <tr>
                        <td>@notif.ObavijestID</td>
                        <td>@notif.Naslov</td>
                        <td>
                            @(notif.Sadrzaj.Length > 30
                                ? notif.Sadrzaj.Substring(0, 30) + "..."
                                : notif.Sadrzaj)
                        </td>
                        <td>@notif.TipObavijesti</td>
                        <td>@notif.Datum.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Zaposlenik"
                                   asp-action="EditNotification"
                                   asp-route-id="@notif.ObavijestID"
                                   class="btn btn-sm btn-warning">
                                Uredi
                            </a>

                            <form method="post"
                                  asp-controller="Zaposlenik"
                                  asp-action="DeleteNotification"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@notif.ObavijestID" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Obriši
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema obavijesti.
        </div>
    }
</div>