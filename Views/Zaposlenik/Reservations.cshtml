@model IEnumerable<Task6.Models.Rezervacija>

@{
    ViewData["Title"] = "Upravljanje rezervacijama";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Upravljanje rezervacijama</h1>
        </div>

        <a asp-controller="Zaposlenik"
               asp-action="Dashboard"
               class="home-btn">
            Zaposlenik panel
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="admin-table-box">

            <table class="table admin-table">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Korisnik</th>
                        <th>Soba</th>
                        <th>Datum</th>
                        <th>Vrijeme</th>
                        <th>Broj osoba</th>
                        <th>Status</th>
                        <th>Kreirana</th>
                        <th>Akcije</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var res in Model)
                    {
                        <tr>

                            <td>@res.RezervacijaID</td>

                            <td>
                                @res.Korisnik.Ime @res.Korisnik.Prezime
                            </td>

                            <td>
                                @res.Termin.EscapeRoom.Naziv
                            </td>

                            <td>
                                @res.Termin.Datum.ToString("dd.MM.yyyy")
                            </td>

                            <td>
                                @res.Termin.Vrijeme
                            </td>

                            <td>
                                @res.BrojOsoba
                            </td>

                            <td>
                                @if (res.Status)
                                {
                                    <span class="status-badge status-ok">
                                        Potvrđena
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-cancel">
                                        Otkazana
                                    </span>
                                }
                            </td>

                            <td>
                                @res.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")
                            </td>

                            <td>
                                <a asp-controller="Zaposlenik"
                                       asp-action="ReservationDetails"
                                       asp-route-id="@res.RezervacijaID"
                                       class="admin-edit-btn">
                                    Detalji
                                </a>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="empty-reservations">
            Nema rezervacija.
        </div>
    }

</div>