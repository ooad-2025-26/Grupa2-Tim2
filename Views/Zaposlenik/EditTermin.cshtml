@model Task6.Models.Termin

@{
    ViewData["Title"] = "Uredi termin";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h1>Uredi termin</h1>

            <form method="post" class="card p-4 mt-4">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="TerminID" />

                <div class="mb-3">
                    <label class="form-label">Escape soba</label>
                    <select asp-for="RoomID" class="form-select">
                        @foreach (var room in ViewBag.Rooms)
                        {
                            <option value="@room.RoomID">
                                @room.Naziv
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Datum" class="form-label"></label>
                    <input asp-for="Datum" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Vrijeme" class="form-label"></label>
                    <input asp-for="Vrijeme" class="form-control" />
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Dostupnost" class="form-check-input" />
                    <label asp-for="Dostupnost" class="form-check-label">
                        Dostupan
                    </label>
                </div>

                <button type="submit" class="btn btn-warning">
                    Sačuvaj izmjene
                </button>

                <a asp-action="Termini" class="btn btn-secondary">
                    Otkaži
                </a>
            </form>

        </div>
    </div>
</div>