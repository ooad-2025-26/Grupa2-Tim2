@model Task6.Models.Termin

@{
    ViewData["Title"] = "Uredi termin";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Uredi termin</h1>
        </div>

        <a asp-controller="Zaposlenik"
               asp-action="Dashboard"
               class="home-btn">
            Zaposlenik panel
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <form method="post" class="admin-form-card">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="TerminID" />

                <div class="mb-3">
                    <label class="form-label">Escape soba</label>
                    <select asp-for="RoomID" class="form-select">
                        @foreach (var room in ViewBag.Rooms)
                        {
                            <option value="@room.RoomID">
                                @room.Naziv
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Datum" class="form-label">
                        Datum
                    </label>

                    <input asp-for="Datum"
                           type="date"
                           min="@DateTime.Now.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Vrijeme" class="form-label">
                        Vrijeme
                    </label>

                    <input asp-for="Vrijeme"
                           type="time"
                           class="form-control" />
                </div>

                <div class="form-check mb-4">
                    <input asp-for="Dostupnost"
                           class="form-check-input" />

                    <label asp-for="Dostupnost"
                           class="form-check-label">
                        Dostupan
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="admin-add-btn">
                        Sačuvaj izmjene
                    </button>

                    <a asp-controller="Zaposlenik"
                           asp-action="Termini"
                           class="admin-edit-btn">
                        Otkaži
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var datumInput = document.getElementById('Datum');
            var vrijemeInput = document.getElementById('Vrijeme');

            var danas = '@DateTime.Now.ToString("yyyy-MM-dd")';
            var sada = '@DateTime.Now.ToString("HH:mm")';

            function azurirajMinVrijeme() {
                if (datumInput.value === danas) {
                    vrijemeInput.min = sada;
                } else {
                    vrijemeInput.removeAttribute('min');
                }
            }

            datumInput.addEventListener('change', azurirajMinVrijeme);
            azurirajMinVrijeme();
        });
    </script>
}