@model Task6.Models.Obavijest

@{
    ViewData["Title"] = "Uredi obavijest";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Uredi obavijest</h1>
        </div>

        <a asp-controller="Zaposlenik"
               asp-action="Dashboard"
               class="home-btn">
            Zaposlenik panel
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <form method="post" class="admin-form-card">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ObavijestID" />
                <input type="hidden" asp-for="Datum" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Naslov" class="form-label">
                        Naslov
                    </label>

                    <input asp-for="Naslov"
                           class="form-control" />

                    <span asp-validation-for="Naslov"
                          class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Sadrzaj" class="form-label">
                        Sadržaj
                    </label>

                    <textarea asp-for="Sadrzaj"
                              class="form-control"
                              rows="5"></textarea>

                    <span asp-validation-for="Sadrzaj"
                          class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="TipObavijesti"
                           class="form-label">
                        Tip obavijesti
                    </label>

                    <select asp-for="TipObavijesti"
                            class="form-select">
                        <option value="Novost">Novost</option>
                        <option value="Popust">Popust</option>
                        <option value="Rezervacija">Rezervacija</option>
                        <option value="Otkazivanje">Otkazivanje</option>
                    </select>

                    <span asp-validation-for="TipObavijesti"
                          class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="admin-edit-btn">
                        Sačuvaj izmjene
                    </button>

                    <a asp-controller="Zaposlenik"
                           asp-action="Notifications"
                           class="admin-delete-btn">
                        Otkaži
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}