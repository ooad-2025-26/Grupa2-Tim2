@model IEnumerable<Task6.Models.Recenzija>

@{
    ViewData["Title"] = "Upravljanje recenzijama";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upravljanje recenzijama</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Korisnik</th>
                    <th>Soba</th>
                    <th>Ocjena</th>
                    <th>Komentar</th>
                    <th>Datum</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var review in Model)
                {
                    <tr>
                        <td>@review.RecenzijaID</td>
                        <td>@review.Korisnik.Ime @review.Korisnik.Prezime</td>
                        <td>@review.EscapeRoom.Naziv</td>
                        <td><span class="text-warning">@review.Ocjena ⭐</span></td>
                        <td>@review.Komentar?.Substring(0, Math.Min(30, review.Komentar?.Length ?? 0))...</td>
                        <td>@review.Datum.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Zaposlenik" asp-action="DeleteReview" asp-route-id="@review.RecenzijaID" 
                               class="btn btn-sm btn-danger">Obriši</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema recenzija.
        </div>
    }
</div>
