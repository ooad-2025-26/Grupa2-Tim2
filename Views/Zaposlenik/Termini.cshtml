@model IEnumerable<Task6.Models.Termin>

@{
    ViewData["Title"] = "Upravljanje terminima";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Upravljanje terminima</h1>
        </div>

        <a asp-controller="Zaposlenik"
               asp-action="Dashboard"
               class="home-btn">
            Zaposlenik panel
        </a>
    </div>

    <a asp-controller="Zaposlenik"
           asp-action="CreateTermin"
           class="admin-add-btn">
        + Novi termin
    </a>

    @if (Model.Any())
    {
        <div class="admin-table-box">

            <table class="table admin-table">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Soba</th>
                        <th>Datum</th>
                        <th>Vrijeme</th>
                        <th>Dostupnost</th>
                        <th>Akcije</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var termin in Model)
                    {
                        <tr>

                            <td>@termin.TerminID</td>

                            <td>@termin.EscapeRoom.Naziv</td>

                            <td>
                                @termin.Datum.ToString("dd.MM.yyyy")
                            </td>

                            <td>@termin.Vrijeme</td>

                            <td>
                                @if (termin.Dostupnost)
                                {
                                    <span class="status-badge status-ok">
                                        Dostupan
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-cancel">
                                        Zauzet
                                    </span>
                                }
                            </td>

                            <td>

                                <a asp-controller="Zaposlenik"
                                       asp-action="EditTermin"
                                       asp-route-id="@termin.TerminID"
                                       class="admin-edit-btn">
                                    Uredi
                                </a>

                                <a asp-controller="Zaposlenik"
                                       asp-action="DeleteTermin"
                                       asp-route-id="@termin.TerminID"
                                       class="admin-delete-btn">
                                    Obriši
                                </a>

                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="empty-reservations">
            Nema termina.

            <br /><br />

            <a asp-controller="Zaposlenik"
                   asp-action="CreateTermin"
                   class="admin-add-btn">
                Kreiraj prvi termin
            </a>
        </div>
    }

</div>