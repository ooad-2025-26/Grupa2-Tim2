@model IEnumerable<Task6.Models.Termin>

@{
    ViewData["Title"] = "Upravljanje terminima";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upravljanje terminima</h1>

    <a asp-controller="Zaposlenik" asp-action="CreateTermin" class="btn btn-success mb-3">
        + Novi termin
    </a>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Soba</th>
                    <th>Datum</th>
                    <th>Vrijeme</th>
                    <th>Dostupnost</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var termin in Model)
                {
                    <tr>
                        <td>@termin.TerminID</td>
                        <td>@termin.EscapeRoom.Naziv</td>
                        <td>@termin.Datum.ToString("dd.MM.yyyy")</td>
                        <td>@termin.Vrijeme</td>
                        <td>
                            @if (termin.Dostupnost)
                            {
                                <span class="badge bg-success">Dostupan</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Zauzet</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Zaposlenik"
                                   asp-action="EditTermin"
                                   asp-route-id="@termin.TerminID"
                                   class="btn btn-sm btn-warning">
                                Uredi
                            </a>

                            <a asp-controller="Zaposlenik"
                                   asp-action="DeleteTermin"
                                   asp-route-id="@termin.TerminID"
                                   class="btn btn-sm btn-danger">
                                Obriši
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema termina.
        </div>
    }
</div>