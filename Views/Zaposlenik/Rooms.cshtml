@model IEnumerable<Task6.Models.EscapeRoom>

@{
    ViewData["Title"] = "Upravljanje sobama";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upravljanje Escape Sobama</h1>

    <a asp-controller="Zaposlenik" asp-action="CreateRoom" class="btn btn-success mb-3">+ Nova soba</a>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Naziv</th>
                    <th>Opis</th>
                    <th>Težina</th>
                    <th>Kapacitet</th>
                    <th>Cijena (KM)</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in Model)
                {
                    <tr>
                        <td>@room.RoomID</td>
                        <td>@room.Naziv</td>
                        <td>@room.Opis.Substring(0, Math.Min(30, room.Opis.Length))...</td>
                        <td>@room.Tezina</td>
                        <td>@room.Kapacitet</td>
                        <td>@room.Cijena</td>
                        <td>
                            <a asp-controller="Zaposlenik" asp-action="EditRoom" asp-route-id="@room.RoomID"
                               class="btn btn-sm btn-warning">Uredi</a>
                            <a asp-controller="Zaposlenik" asp-action="DeleteRoom" asp-route-id="@room.RoomID"
                               class="btn btn-sm btn-danger">Obriši</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema registrovanih soba. <a asp-controller="Zaposlenik" asp-action="CreateRoom">Kreiraj prvu sobu</a>
        </div>
    }
</div>
