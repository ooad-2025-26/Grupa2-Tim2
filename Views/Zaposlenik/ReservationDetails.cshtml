@model Task6.Models.Rezervacija

@{
    ViewData["Title"] = "Detalji rezervacije";

    var terminDateTime = Model.Termin.Datum.Date;
    if (TimeSpan.TryParse(Model.Termin.Vrijeme, out var terminVrijeme))
    {
        terminDateTime = terminDateTime.Add(terminVrijeme);
    }
    var terminProsao = terminDateTime < DateTime.Now;
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Detalji rezervacije</h1>
        </div>

    </div>

    <div class="admin-form-card">

        <div class="row">

            <div class="col-md-6 mb-3">
                <strong>ID rezervacije</strong>
                <p>@Model.RezervacijaID</p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Status</strong>
                <p>
                    @if (Model.Status)
                    {
                        <span class="status-badge status-ok">
                            Potvrđena
                        </span>
                    }
                    else
                    {
                        <span class="status-badge status-cancel">
                            Otkazana
                        </span>
                    }
                </p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Korisnik</strong>
                <p>@Model.Korisnik.Ime @Model.Korisnik.Prezime</p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Email</strong>
                <p>@Model.Korisnik.Email</p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Escape soba</strong>
                <p>@Model.Termin.EscapeRoom.Naziv</p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Broj osoba</strong>
                <p>@Model.BrojOsoba</p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Datum</strong>
                <p>@Model.Termin.Datum.ToString("dd.MM.yyyy")</p>
            </div>

            <div class="col-md-6 mb-3">
                <strong>Vrijeme</strong>
                <p>@Model.Termin.Vrijeme</p>
            </div>

            <div class="col-md-12">
                <strong>Kreirana</strong>
                <p>@Model.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</p>
            </div>

        </div>

        <div class="mt-4">
            <a asp-controller="Zaposlenik"
                   asp-action="Reservations"
                   class="admin-edit-btn">
                Nazad na rezervacije
            </a>
            
            @if (!terminProsao)
            {
                <form asp-action="Cancel" method="post" style="display:inline; margin-left:10px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.RezervacijaID" />
                    <button type="submit" class="admin-delete-btn" onclick="return confirmCancelReservation(event, this.form)">
                        Otkaži rezervaciju
                    </button>
                </form>
            }
        </div>

    </div>

</div>

@section Scripts {
    <script>
        function confirmCancelReservation(event, form) {
            event.preventDefault();

            Swal.fire({
                title: 'Otkazati rezervaciju?',
                text: 'Rezervacija će biti trajno izbrisana, a korisnik obaviješten o otkazivanju. Ova akcija se ne može poništiti.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Otkaži rezervaciju',
                cancelButtonText: 'Odustani',
                confirmButtonColor: '#c94a4a',
                cancelButtonColor: '#1f4f54'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });

            return false;
        }
    </script>
}