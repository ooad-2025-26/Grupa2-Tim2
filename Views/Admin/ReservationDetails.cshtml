@model Task6.Models.Rezervacija

@{
    ViewData["Title"] = "Detalji rezervacije";
}

<div class="container mt-5">
    <h1>Detalji rezervacije</h1>

    <div class="card p-4 mt-4">
        <p><strong>ID:</strong> @Model.RezervacijaID</p>
        <p><strong>Korisnik:</strong> @Model.Korisnik.Ime @Model.Korisnik.Prezime</p>
        <p><strong>Email:</strong> @Model.Korisnik.Email</p>
        <p><strong>Soba:</strong> @Model.Termin.EscapeRoom.Naziv</p>
        <p><strong>Datum:</strong> @Model.Termin.Datum.ToString("dd.MM.yyyy")</p>
        <p><strong>Vrijeme:</strong> @Model.Termin.Vrijeme</p>
        <p><strong>Broj osoba:</strong> @Model.BrojOsoba</p>
        <p><strong>Status:</strong> @(Model.Status ? "Potvrđena" : "Otkazana")</p>
        <p><strong>Kreirana:</strong> @Model.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</p>

        <a asp-controller="Admin" asp-action="Reservations" class="btn btn-secondary mt-3">
            Nazad na rezervacije
        </a>
    </div>
</div>