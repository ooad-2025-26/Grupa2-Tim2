@model Task6.Models.Obavijest

@{
    ViewData["Title"] = "Uredi obavijest";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h1>Uredi obavijest</h1>

            <form method="post" class="card p-4 mt-4">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ObavijestID" />
                <input type="hidden" asp-for="Datum" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Naslov" class="form-label"></label>
                    <input asp-for="Naslov" class="form-control" />
                    <span asp-validation-for="Naslov" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Sadrzaj" class="form-label"></label>
                    <textarea asp-for="Sadrzaj" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Sadrzaj" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TipObavijesti" class="form-label"></label>
                    <select asp-for="TipObavijesti" class="form-select">
                        <option value="Novost">Novost</option>
                        <option value="Popust">Popust</option>
                        <option value="Rezervacija">Rezervacija</option>
                        <option value="Otkazivanje">Otkazivanje</option>
                    </select>
                    <span asp-validation-for="TipObavijesti" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning">Sačuvaj izmjene</button>
                    <a asp-controller="Admin" asp-action="Notifications" class="btn btn-secondary">Otkaži</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}