@model IEnumerable<Task6.Models.Placanje>

@{
    ViewData["Title"] = "Upravljanje plaćanjima";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upravljanje plaćanjima</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Korisnik</th>
                    <th>Iznos (KM)</th>
                    <th>Datum</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>@payment.PlacanjeID</td>

                        <td>
                            @payment.Rezervacija.Korisnik.Ime
                            @payment.Rezervacija.Korisnik.Prezime
                        </td>

                        <td>@payment.Iznos</td>

                        <td>@payment.Datum.ToString("dd.MM.yyyy HH:mm")</td>

                        <td>
                            @if (payment.Status)
                            {
                                <span class="badge bg-success">Plaćeno</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Nije plaćeno</span>
                            }
                        </td>

                        <td>
                            <form method="post"
                                  asp-controller="Admin"
                                  asp-action="UpdatePaymentStatus"
                                  class="d-inline">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@payment.PlacanjeID" />
                                <input type="hidden" name="status" value="@(!payment.Status)" />

                                @if (payment.Status)
                                {
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        Označi kao neplaćeno
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-success">
                                        Označi kao plaćeno
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema plaćanja.
        </div>
    }
</div>