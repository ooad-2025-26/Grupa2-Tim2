@model IEnumerable<Task6.Models.Placanje>

@{
    ViewData["Title"] = "Upravljanje plaćanjima";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Upravljanje plaćanjima</h1>
        </div>

        <a asp-controller="Admin"
               asp-action="Dashboard"
               class="home-btn">
            Admin panel
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="admin-table-box">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Korisnik</th>
                        <th>Iznos (KM)</th>
                        <th>Datum</th>
                        <th>Status</th>
                        <th>Akcije</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td>@payment.PlacanjeID</td>

                            <td>
                                @payment.Rezervacija.Korisnik.Ime
                                @payment.Rezervacija.Korisnik.Prezime
                            </td>

                            <td>@payment.Iznos</td>

                            <td>@payment.Datum.ToString("dd.MM.yyyy HH:mm")</td>

                            <td>
                                @if (payment.Status)
                                {
                                    <span class="status-badge status-ok">Plaćeno</span>
                                }
                                else
                                {
                                    <span class="status-badge status-cancel">Nije plaćeno</span>
                                }
                            </td>

                            <td>
                                <form method="post"
                                      asp-controller="Admin"
                                      asp-action="UpdatePaymentStatus"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@payment.PlacanjeID" />
                                    <input type="hidden" name="status" value="@(!payment.Status)" />

                                    @if (payment.Status)
                                    {
                                        <button type="submit" class="admin-edit-btn">
                                            Označi kao neplaćeno
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="admin-delete-btn">
                                            Označi kao plaćeno
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-reservations">
            Nema plaćanja.
        </div>
    }

</div>