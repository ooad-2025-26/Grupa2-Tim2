@model IEnumerable<Task6.Models.Termin>

@{
    ViewData["Title"] = "Upravljanje terminima";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Upravljanje terminima</h1>
        </div>

        <a asp-controller="Admin"
               asp-action="Dashboard"
               class="home-btn">
            Admin panel
        </a>
    </div>

    <a asp-controller="Admin"
           asp-action="CreateTermin"
           class="admin-add-btn">
        + Novi termin
    </a>

    <div class="mb-3">
        <input type="text"
               id="terminSearch"
               class="form-control"
               style="max-width:300px;"
               placeholder="Pretraži po nazivu sobe..." />
    </div>

    @if (Model.Any())
    {
        <div class="admin-table-box">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Soba</th>
                        <th>Datum</th>
                        <th>Vrijeme</th>
                        <th>Dostupnost</th>
                        <th>Akcije</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var termin in Model)
                    {
                        <tr>
                            <td>@termin.TerminID</td>
                            <td>@termin.EscapeRoom.Naziv</td>
                            <td>@termin.Datum.ToString("dd.MM.yyyy")</td>
                            <td>@termin.Vrijeme</td>
                            <td>
                                @if (termin.Dostupnost)
                                {
                                    <span class="status-badge status-ok">Dostupan</span>
                                }
                                else
                                {
                                    <span class="status-badge status-cancel">Zauzet</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Admin"
                                       asp-action="EditTermin"
                                       asp-route-id="@termin.TerminID"
                                       class="admin-edit-btn">
                                    Uredi
                                </a>

                                <a asp-controller="Admin"
                                       asp-action="DeleteTermin"
                                       asp-route-id="@termin.TerminID"
                                       class="admin-delete-btn">
                                    Obriši
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Nema termina.
        </div>
    }

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var searchInput = document.getElementById('terminSearch');
            var rows = document.querySelectorAll('.admin-table tbody tr');

            if (!searchInput) return;

            searchInput.addEventListener('input', function () {
                var query = searchInput.value.trim().toLowerCase();

                rows.forEach(function (row) {
                    var soba = row.children[1].textContent.trim().toLowerCase();
                    row.style.display = soba.includes(query) ? '' : 'none';
                });
            });
        });
    </script>
}