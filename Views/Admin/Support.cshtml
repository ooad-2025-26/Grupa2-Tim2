@model IEnumerable<Task6.Models.Podrska>

@{
    ViewData["Title"] = "Upiti korisnika";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upiti korisnika</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Korisnik</th>
                    <th>Email</th>
                    <th>Naslov</th>
                    <th>Datum</th>
                    <th>Stanje</th>
                    <th>Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var support in Model)
                {
                    <tr>
                        <td>@support.PorukaID</td>
                        <td>@support.Korisnik?.Ime @support.Korisnik?.Prezime</td>
                        <td>@support.Email</td>
                        <td>@support.NaslovPoruke</td>
                        <td>@support.Datum.ToString("dd.MM.yyyy HH:mm")</td>

                        <td>
                            @if (support.Odgovoreno)
                            {
                                <span class="badge bg-success">Odgovoreno</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Neodgovoreno</span>
                            }
                        </td>

                        <td>
                            <a asp-controller="Admin"
                               asp-action="SupportDetails"
                               asp-route-id="@support.PorukaID"
                               class="btn btn-sm btn-info">
                                Pregled
                            </a>

                            <form asp-controller="Admin"
                                  asp-action="DeleteSupport"
                                  method="post"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@support.PorukaID" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Obriši
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Nema upita korisnika.
        </div>
    }
</div>