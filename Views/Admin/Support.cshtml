@model IEnumerable<Task6.Models.Podrska>

@{
    ViewData["Title"] = "Podrška korisnicima";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Poruke podrške</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Korisnik</th>
                    <th>Email</th>
                    <th>Naslov</th>
                    <th>Datum</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var support in Model)
                {
                    <tr>
                        <td>@support.PorukaID</td>
                        <td>@support.Korisnik?.Ime @support.Korisnik?.Prezime</td>
                        <td>@support.Email</td>
                        <td>@support.NaslovPoruke</td>
                        <td>@support.Datum.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Admin" asp-action="SupportDetails" asp-route-id="@support.PorukaID" 
                               class="btn btn-sm btn-info">Pregled</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema poruka podrške.
        </div>
    }
</div>
