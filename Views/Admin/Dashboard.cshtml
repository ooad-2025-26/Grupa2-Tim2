@{
    ViewData["Title"] = "Admin Panel";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Admin Panel</h1>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Ukupno korisnika</h5>
                    <h3>@ViewBag.Stats.TotalUsers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Escape sobe</h5>
                    <h3>@ViewBag.Stats.TotalRooms</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Rezervacije</h5>
                    <h3>@ViewBag.Stats.TotalReservations</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Neplaćanja</h5>
                    <h3>@ViewBag.Stats.PendingPayments</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card text-white bg-secondary">
                <div class="card-body">
                    <h5 class="card-title">Recenzije</h5>
                    <h3>@ViewBag.Stats.TotalReviews</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-white bg-dark">
                <div class="card-body">
                    <h5 class="card-title">Prosječna ocjena</h5>
                    <h3>@ViewBag.Stats.AverageRating.ToString("F1") ⭐</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Brzine akcije</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Rooms" class="btn btn-primary w-100">Upravljaj sobama</a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Termini" class="btn btn-success w-100">Upravljaj terminima</a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Reservations" class="btn btn-info w-100">Rezervacije</a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Payments" class="btn btn-warning w-100">Plaćanja</a>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Reviews" class="btn btn-secondary w-100">Recenzije</a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Notifications" class="btn btn-dark w-100">Obavijesti</a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a asp-controller="Admin" asp-action="Support" class="btn btn-outline-primary w-100">Podrška</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
