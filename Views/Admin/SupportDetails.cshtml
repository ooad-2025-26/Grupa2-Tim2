@model Task6.Models.Podrska

@{
    ViewData["Title"] = "Detalji upita";
}

<div class="container mt-5">
    <h1>Detalji upita</h1>

    <div class="card p-4">
        <p><strong>Korisnik:</strong> @Model.Korisnik?.Ime @Model.Korisnik?.Prezime</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Naslov:</strong> @Model.NaslovPoruke</p>
        <p><strong>Datum:</strong> @Model.Datum.ToString("dd.MM.yyyy HH:mm")</p>

        <hr />

        <h4>Poruka</h4>
        <p>@Model.Sadrzaj</p>

        <hr />

        <p>
            <strong>Status:</strong>
            @if (Model.Odgovoreno)
            {
                <span class="badge bg-success">Odgovoreno</span>
            }
            else
            {
                <span class="badge bg-warning">Neodgovoreno</span>
            }
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.Odgovor))
        {
            <h4>Poslani odgovor</h4>
            <div class="alert alert-success">
                @Model.Odgovor
            </div>
            <p><strong>Datum odgovora:</strong> @Model.DatumOdgovora?.ToString("dd.MM.yyyy HH:mm")</p>
        }

        @if (!Model.Odgovoreno)
        {
            <form asp-controller="Admin" asp-action="ReplySupport" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="id" value="@Model.PorukaID" />

                <div class="mb-3">
                    <label class="form-label">Odgovor korisniku</label>
                    <textarea name="odgovor" class="form-control" rows="5" required></textarea>
                </div>

                <button type="submit" class="btn btn-success">
                    Pošalji odgovor
                </button>
            </form>
        }

        <hr />

        <a asp-controller="Admin" asp-action="Support" class="btn btn-secondary">
            Nazad
        </a>
    </div>
</div>