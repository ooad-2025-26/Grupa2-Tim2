@model IEnumerable<Task6.Models.Rezervacija>

@{
    ViewData["Title"] = "Upravljanje rezervacijama";
}

<div class="container-fluid mt-5">
    <h1 class="mb-4">Upravljanje rezervacijama</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Korisnik</th>
                    <th>Soba</th>
                    <th>Datum</th>
                    <th>Vrijeme</th>
                    <th>Osoba</th>
                    <th>Status</th>
                    <th>Kreirana</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var res in Model)
                {
                    <tr>
                        <td>@res.RezervacijaID</td>
                        <td>@res.Korisnik.Ime @res.Korisnik.Prezime</td>
                        <td>@res.Termin.EscapeRoom.Naziv</td>
                        <td>@res.Termin.Datum.ToString("dd.MM.yyyy")</td>
                        <td>@res.Termin.Vrijeme</td>
                        <td>@res.BrojOsoba</td>
                        <td>
                            @if (res.Status)
                            {
                                <span class="badge bg-success">Potvrđena</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Otkazana</span>
                            }
                        }
                        </td>
                        <td>@res.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Admin" asp-action="ReservationDetails" asp-route-id="@res.RezervacijaID" 
                               class="btn btn-sm btn-info">Detalji</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            Nema rezervacija.
        </div>
    }
</div>
