@model IEnumerable<Task6.Models.Rezervacija>

@{
    ViewData["Title"] = "Upravljanje rezervacijama";
}

<div class="admin-page">

    <div class="admin-header">
        <div>
            <p class="profile-small-title">THE LAST KEY</p>
            <h1>Upravljanje rezervacijama</h1>
        </div>

        <a asp-controller="Admin"
               asp-action="Dashboard"
               class="home-btn">
            Admin panel
        </a>
    </div>

    @if (TempData["CancelSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["CancelSuccess"]</div>
    }

    @if (TempData["CancelError"] != null)
    {
        <div class="alert alert-danger">@TempData["CancelError"]</div>
    }

    @if (Model.Any())
    {
        <div class="profile-table-wrapper">
            <table class="profile-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Korisnik</th>
                        <th>Soba</th>
                        <th>Datum</th>
                        <th>Vrijeme</th>
                        <th>Osoba</th>
                        <th>Status</th>
                        <th>Kreirana</th>
                        <th>Akcije</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var res in Model)
                    {
                        var terminDateTime = res.Termin.Datum.Date;
                        if (TimeSpan.TryParse(res.Termin.Vrijeme, out var terminVrijeme))
                        {
                            terminDateTime = terminDateTime.Add(terminVrijeme);
                        }
                        var terminProsao = terminDateTime < DateTime.Now;

                        <tr>
                            <td>@res.RezervacijaID</td>

                            <td>
                                @res.Korisnik.Ime
                                @res.Korisnik.Prezime
                            </td>

                            <td>@res.Termin.EscapeRoom.Naziv</td>

                            <td>
                                @res.Termin.Datum.ToString("dd.MM.yyyy")
                            </td>

                            <td>@res.Termin.Vrijeme</td>

                            <td>@res.BrojOsoba</td>

                            <td>
                                @if (res.Status)
                                {
                                    <span class="status-badge status-ok">
                                        Potvrđena
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-cancel">
                                        Otkazana
                                    </span>
                                }
                            </td>

                            <td>
                                @res.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")
                            </td>

                            <td class="action-buttons">
                                <a asp-controller="Admin"
                                       asp-action="ReservationDetails"
                                       asp-route-id="@res.RezervacijaID"
                                       class="details-btn">
                                    Detalji
                                </a>

                                @if (!terminProsao)
                                {
                                    <form asp-action="Cancel" method="post" style="display:inline; margin-left:8px;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@res.RezervacijaID" />
                                        <button type="submit" class="admin-delete-btn" onclick="return confirmCancelReservation(event, this.form)">
                                            Otkaži
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-reservations">
            Nema rezervacija.
        </div>
    }

</div>

@section Scripts {
    <script>
        function confirmCancelReservation(event, form) {
            event.preventDefault();

            Swal.fire({
                title: 'Otkazati rezervaciju?',
                text: 'Rezervacija će biti trajno izbrisana, a korisnik obaviješten o otkazivanju. Ova akcija se ne može poništiti.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Otkaži rezervaciju',
                cancelButtonText: 'Odustani',
                confirmButtonColor: '#c94a4a',
                cancelButtonColor: '#1f4f54'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });

            return false;
        }
    </script>
}