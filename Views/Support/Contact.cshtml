@model Task6.Models.Podrska

@{
    ViewData["Title"] = "Dodatna pitanja";
}

<div class="question-page">
    <div class="question-card">

        <a asp-controller="Profil"
               asp-action="Index"
               class="back-profile-btn">
            ← Nazad na profil
        </a>

        <p class="profile-small-title">THE LAST KEY</p>
        <h1>Dodatna pitanja</h1>

        <p class="question-subtitle">
            Imate dodatno pitanje vezano za rezervaciju, plaćanje ili escape room?
            Pošaljite nam upit i odgovor ćete dobiti putem emaila.
        </p>

        @if (TempData["SupportSuccess"] != null)
        {
            <div class="alert alert-success">
                @TempData["SupportSuccess"]
            </div>
        }

        <form asp-controller="Support"
              asp-action="Contact"
              method="post"
              class="question-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="NaslovPoruke" class="form-label">Naslov pitanja</label>
                <input asp-for="NaslovPoruke"
                       class="form-control"
                       placeholder="Tema pitanja"
                       maxlength="100"
                       required />
                <span asp-validation-for="NaslovPoruke" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email"
                       class="form-control"
                       type="email"
                       value="@ViewBag.Email"
                       placeholder="vas@email.com"
                       readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Sadrzaj" class="form-label">Vaše pitanje</label>
                <textarea asp-for="Sadrzaj"
                          class="form-control"
                          rows="5"
                          maxlength="500"
                          placeholder="Napišite vaše pitanje..."
                          required></textarea>
                <span asp-validation-for="Sadrzaj" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="question-submit-btn">
                    Pošalji pitanje
                </button>

                <a asp-controller="Profil"
                       asp-action="Index"
                       class="question-cancel-btn">
                    Otkaži
                </a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}